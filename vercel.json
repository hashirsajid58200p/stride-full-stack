{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|txt|woff|woff2|webp|webmanifest|map|mp4|webm|ogg|mp3|wav)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "client/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}
