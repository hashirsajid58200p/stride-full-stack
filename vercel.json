{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/public/(.*)",
      "dest": "client/public/$1"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "client/src/scripts/$1"
    },
    {
      "src": "/styles/(.*)",
      "dest": "client/src/styles/$1"
    },
    {
      "src": "/components/(.*)",
      "dest": "client/src/components/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "client/src/pages/$1"
    },
    {
      "src": "/",
      "dest": "client/src/pages/index.html"
    },
    {
      "src": "/(.*).html",
      "dest": "client/src/pages/$1.html"
    }
  ]
}
